// mais testes de comentario lalalalalalala

class Calculadora {
    int ult_resp;

    public int soma(int a, int b) {
        int temp;
        temp = a + b;
        ult_resp = temp;
        return temp;
    }
}

//testando chamar calculadora em teste

class Teste{
    public int execTeste(){
        int aux;
        int status;
        
        aux = new Calculadora().soma(10, 20);
        
        if(aux > 20){
            status = 1;
            System.out.println(status);
        }
        else{
            status = 0;
        }
        
        return status;
    }
}